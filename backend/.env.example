# ================================
# DATABASE CONFIGURATION
# ================================
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/hoashop"

# ================================
# JWT AUTHENTICATION
# ================================
# Secret keys for JWT tokens (CHANGE IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production-min-32-chars"

# Token expiration times
JWT_EXPIRES_IN="1d"           # Access token: 1 day
JWT_REFRESH_EXPIRES_IN="7d"   # Refresh token: 7 days

# ================================
# CLOUDINARY (Image Upload)
# ================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ================================
# GOOGLE GEMINI AI
# ================================
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ================================
# EMAIL SERVICE (Optional)
# ================================
# For production: Use SendGrid, AWS SES, Resend, etc.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="noreply@hoashop.com"

# SendGrid (Recommended)
# SENDGRID_API_KEY="your-sendgrid-api-key"
# SENDGRID_FROM_EMAIL="noreply@hoashop.com"

# ================================
# APPLICATION
# ================================
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Environment: development | production | test
NODE_ENV="development"

# ================================
# PAYMENT GATEWAYS (Optional)
# ================================
# Momo Payment
# MOMO_PARTNER_CODE="your-partner-code"
# MOMO_ACCESS_KEY="your-access-key"
# MOMO_SECRET_KEY="your-secret-key"
# MOMO_ENDPOINT="https://test-payment.momo.vn"

# VNPay
# VNPAY_TMN_CODE="your-tmn-code"
# VNPAY_HASH_SECRET="your-hash-secret"
# VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# VNPAY_RETURN_URL="http://localhost:3000/payment/vnpay/callback"

# ================================
# REDIS CACHE (Optional)
# ================================
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD=""

# ================================
# LOGGING & MONITORING (Optional)
# ================================
# SENTRY_DSN="your-sentry-dsn"
# LOG_LEVEL="info"
